# NanoHA Configuration
# Copy to .env and fill in your values

# LLM Provider: anthropic, openai, google, ollama
LLM_PROVIDER=anthropic

# API Key (not needed for Ollama)
LLM_API_KEY=your-api-key-here

# Home Assistant (auto-configured by agent)
HA_URL=http://homeassistant:8123
HA_TOKEN=

# Telegram (optional — talk to @BotFather to create a bot)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=[]

# Google Cloud STT (optional — for higher quality speech recognition)
# Set to "true" to use Google Cloud STT instead of local Whisper
GOOGLE_CLOUD_STT_ENABLED=false
GOOGLE_CLOUD_API_KEY=
